{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Hypho/pact/.pact/schemas/queue.schema.json",
  "title": "PACT Feature Queue",
  "description": "Draft schema for a future structured feature queue. In v1.x, state.md remains the source of truth and queue.json is not enabled.",
  "type": "object",
  "required": ["version", "source", "features"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "source": {
      "type": "string",
      "const": "draft"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "title", "priority", "status", "phase", "depends_on", "blocked_reason", "artifacts"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F-[0-9]{3,}$"
          },
          "name": {
            "type": "string",
            "description": "Canonical feature name. Must match PACT artifact file naming rules."
          },
          "title": {
            "type": "string"
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "type": "string",
            "enum": ["queued", "active", "blocked", "shipped", "cancelled"]
          },
          "phase": {
            "type": "string",
            "enum": ["待开始", "pid", "contract", "build", "build-complete", "verify-pass", "shipped"]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^F-[0-9]{3,}$"
            },
            "uniqueItems": true
          },
          "blocked_reason": {
            "type": "string"
          },
          "artifacts": {
            "type": "object",
            "required": ["pid", "contract", "verify"],
            "additionalProperties": false,
            "properties": {
              "pid": {
                "type": "string"
              },
              "contract": {
                "type": "string"
              },
              "verify": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
