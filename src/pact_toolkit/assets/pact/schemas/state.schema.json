{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Hypho/pact/.pact/schemas/state.schema.json",
  "title": "PACT State",
  "description": "Draft schema for a future structured PACT state source. In v1.x, state.md remains the source of truth.",
  "type": "object",
  "required": ["current", "queue", "completed"],
  "additionalProperties": false,
  "properties": {
    "current": {
      "type": "object",
      "required": ["feature", "phase", "started_at", "doing", "blocked"],
      "additionalProperties": false,
      "properties": {
        "feature": {
          "type": "string",
          "description": "Current feature name. Must match generated PACT file paths when active."
        },
        "phase": {
          "type": "string",
          "enum": ["待开始", "pid", "contract", "build", "build-complete", "verify-pass", "shipped"]
        },
        "started_at": {
          "type": "string",
          "description": "Feature start time in YYYY-MM-DD HH:mm format, or an empty string when idle."
        },
        "doing": {
          "type": "string"
        },
        "blocked": {
          "type": "string"
        }
      }
    },
    "queue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature"],
        "additionalProperties": false,
        "properties": {
          "feature": {
            "type": "string"
          }
        }
      }
    },
    "completed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature", "started_at", "completed_at", "contract_count", "test_summary", "verify"],
        "additionalProperties": false,
        "properties": {
          "feature": {
            "type": "string"
          },
          "started_at": {
            "type": "string"
          },
          "completed_at": {
            "type": "string"
          },
          "contract_count": {
            "type": "integer",
            "minimum": 0
          },
          "test_summary": {
            "type": "string"
          },
          "verify": {
            "type": "string"
          }
        }
      }
    }
  }
}
